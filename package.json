{
  "name": "scry-ui",
  "version": "0.1.0",
  "description": "A clean web UI for the scry code-search index. Mithril SPA + Express proxy in front of `scry serve`.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.19"
  },
  "scripts": {
    "dev": "concurrently -k -n api,ui -c blue,magenta npm:dev:api npm:dev:ui",
    "dev:api": "tsx watch server/index.ts",
    "dev:ui": "vite",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "fmt": "prettier --write \"{server,src,shared}/**/*.{ts,scss}\" \"*.{json,md}\""
  },
  "dependencies": {
    "express": "^4.21.2",
    "mithril": "^2.2.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/mithril": "^2.2.6",
    "@types/node": "^20.14.0",
    "concurrently": "^9.1.0",
    "prettier": "^3.3.3",
    "sass": "^1.80.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
